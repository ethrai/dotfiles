format=<b>%a ⏵</b> %s\n%b
font=monospace 14
sort=-time
# output=eDP-1
layer=overlay
anchor=top-right
width=350
height=120
margin=5
padding=0,5,10
border-size=2
border-radius=6
icons=0
max-icon-size=64
default-timeout=4000
ignore-timeout=1

# Colors
background-color=#26233a
text-color=#e0def4
border-color=#ebbcba
progress-color=over #31748f

[urgency=high]
border-color=#eb6f92
