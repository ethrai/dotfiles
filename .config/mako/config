format=<b>%a ⏵</b> %s\n%b
font=monospace 12
sort=-time
# output=eDP-1
layer=overlay
anchor=top-right
width=350
height=120
margin=5
padding=0,5,10
border-size=2
border-radius=6
icons=0
max-icon-size=64
default-timeout=4000
ignore-timeout=1

# Colors
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#cba6f7
progress-color=over #313244

[urgency=high]
border-color=#fab387
