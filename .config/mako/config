format=<b>%a ⏵</b> %s\n%b
font=monospace 14
sort=-time
# output=eDP-1
layer=top
anchor=top-right
width=350
height=120
margin=5
outer-margin=10,0,0,0
padding=0,5,10
border-size=2
border-radius=0
icons=0
max-icon-size=64
default-timeout=4000
ignore-timeout=1

# Colors
background-color=#282828
text-color=#ebdbb2
border-color=#d65d0e
progress-color=over #928374

[urgency=high]
border-color=#fb4934
