{
  "layer": "top",
  "margin-bottom": 1,
  "margin-top": 1,
  "margin-left": 5,
  "margin-right": 5,
  "height": 30,
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
  ],
  "modules-center": [
    "clock"
    // "custom/mediaplayer",
  ],
  "modules-right": [
    "tray",
    "hyprland/language",
    "idle_inhibitor",
    "memory",
    "temperature#cpu",
    "cpu",
    "network",
    "pulseaudio",
    "power-profiles-daemon",
    "battery"
    // "custom/power",
  ],
