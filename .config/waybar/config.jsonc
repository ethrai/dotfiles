      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
    },
  },
  "memory": {
    "interval": 5,
    "format": "{}% î؟…",
    "max-length": 10,
  },
  "tray": {
    "spacing": 10,
  },
  "temperature#cpu": {
    "critical-threshold": 90,
    "on-click": "kitty --class center-float-large btop",
    "format-critical": "{icon} {temperatureC}آ°C",
    "format": "{icon} {temperatureC}آ°C",
    "format-icons": ["ï‹‰", "ï‹ˆ", "ï‹‡"],
    "tooltip": true,
    "interval": 2,
  },
  "clock": {
    "tooltip-format": "{calendar}",
    "format-alt": "îھ°  {:%a, %d %b %Y}",
    "format": "ïگ؛  {:%I:%M %p}",
  },
  "network": {
    "format-wifi": "{icon}",
    "format-icons": [
      "َ°¤¯",
      "َ°¤ں",
      "َ°¤¢",
      "َ°¤¥",
      "َ°¤¨"
    ],
    "format-ethernet": "َ°€‚",
