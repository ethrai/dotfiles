{
  "theme": "Gruvbox Dark Soft",
  "buffer_font_family": "Iosevka SS04",
  "buffer_font_features": {
    "ss04": true
  },
  "buffer_font_size": 22,
  "cursor_blink": false,
  "ui_font_size": 18,
  "vim_mode": true,
  "assistant": {
    "version": "2",
    "enabled": false
  },
  "auto_update": true,
  "vim": {
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": true
  },
  "telemetry": { "diagnostics": false, "metrics": false },
  "tab_bar": { "show": false },
  "features": {
    "inline_completion_provider": "none"
  }
}
