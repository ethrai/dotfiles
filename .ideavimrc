" general
source ~/.vimrc
let mapleader=" "
set showcmd
set showmode
set number
set incsearch
set hlsearch
set ignorecase
set smartcase
set idearefactormode=keep
set visualbell
set noerrorbells
set ideajoin
set ideastatusicon=gray

" PLUGINS
set quickscope
set textobj-indent


" JUMPS AND GOTO'S
nnoremap gi :action GotoImplementation<CR>
nnoremap gD :action GotoTypeDeclaration<CR>
nnoremap gd :action GotoDeclaration<CR>
nnoremap gt :action GotoTest<CR>
nnoremap gs :action GotoSuperMethod<CR>
" nnoremap gb :action Back<CR>
" nnoremap gf :action Forward<CR>

nmap <S-CR> <Action>(QuickJavaDoc)
vmap <S-CR> <Action>(QuickJavaDoc)
nmap gh <Action>(ShowErrorDescription)
noremap <leader>se :action SearchEverywhere<CR>
nnoremap <leader>ss mm`m:action GotoSymbol<CR>
nnoremap <leader>sa mm`m:action GotoAction<CR>
noremap <leader>sf mm`m:action GotoFile<CR>
noremap <leader>sc mm`m:action GotoClass<CR>
noremap <leader>sp mm`m:action FindInPath<CR>
noremap ge mm`m:action GotoNextError<CR>
noremap gw mm`m:action GotoPreviousError<CR>
noremap gb mm`m:action JumpToLastChange<CR>
noremap gf mm`m:action JumpToNextChange<CR>
" Hacks
" U is redo
nnoremap U <C-r>
noremap <silent> <leader><leader> :nohlsearch<CR>
" Do not overwrite unnamed register with x and s
nnoremap x \"_x
nnoremap s \"_s
" Y yank until end of line
nnoremap Y y$
" Create Blank Newlines and stay in Normal mode
nnoremap <silent> zj o<Esc>k
nnoremap <silent> zk O<Esc>j
" Maintain visual selection after indenting
vnoremap < <gv
vnoremap > >gv
" Reselect last patsed text
nnoremap gp `[v`]
" CamelCaseMotion
map w [w
map e ]w
map b [b
" use H as 0 and L as $
map H 0
map L $
" Easymotion
map , <Plug>(easymotion-prefix)
map ,f <Plug>(easymotion-bd-f)
map ,t <Plug>(easymotion-bd-t)
map ,w <Plug>(easymotion-bd-w)
map ,W <Plug>(easymotion-bd-W)
map ,e <Plug>(easymotion-bd-e)
map ,E <Plug>(easymotion-bd-E)
map ,l <Plug>(easymotion-bd-jk)
map ,s <Plug>(easymotion-bd-f2)
map ,S <Plug>(easymotion-bd-t2)
" Splitted editors
map <C-h> <C-w>h
map <C-l> <C-w>l
nmap <leader>ws <Action>(SplitVertically)
map <leader>wu <Action>(Unsplit)
nmap <leader>wq <Action>(CloseContent)
nmap <leader>wh <Action>(CloseAllToTheLeft)
nmap <leader>wl <Action>(CloseAllToTheRight)
nmap <leader>wx <Action>(CloseAllEditorsButActive)
nmap <leader>wr <Action>(ReopenClosedTab)
nmap <leader>wc <Action>(HideAllWindows)
" -------------------------------------------- collapse
nmap zc <Action>(CollapseRegion)
nmap za <Action>(ExpandRegion)
nmap zd <Action>(CollapseAllRegions)
nmap zf <Action>(ExpandAllRegions)
" ---------------------------------------------
nnoremap <leader>ve :e ~/.ideavimrc<CR>
" --------------------------------------------- bookmarks
nmap <leader>bt <Action>(ToggleBookmark)
nmap <leader>bs <Action>(ShowBookmarks)
""""""""""""""""""""""""""""""""""""""Run""""""""""""""""""""""""""""""""""""""
nnoremap <leader>rf :action ChooseRunConfiguration<CR>
noremap <leader>ru :action Run<CR>
noremap <leader>rn :action RunClass<CR>
noremap <leader>rc :action Coverage<CR>
noremap <leader>rv :action RunCoverage<CR>
noremap <leader>sp   :action Stop<CR>
nnoremap <leader>rg :action Gradle.ExecuteTask<CR>
""" Toolwindows
nnoremap <leader>tw :action ToolWindowsGroup<CR>
""""""""""""""""""""""""""""""""""""""Debug""""""""""""""""""""""""""""""""""""""
noremap <leader>dt :action ToggleLineBreakpoint<CR>
noremap <leader>de :action QuickEvaluateExpression <CR>
noremap <leader>de :action EvaluateExpression <CR>
"noremap <leader>fr :action Debugger.ForceEarlyReturn<CR>
noremap <leader>dw :action Debugger.AddToWatch<CR>
noremap <leader>dc :action ForceRunToCursor<CR>
"noremap <leader>hs :action Hotswap<CR>
"noremap <leader>DD :action JRebel Debug<CR>
noremap <leader>df :action Debugger.RemoveAllBreakpointsInFile<CR>
noremap <leader>da :action Debugger.RemoveAllBreakpoints<CR>
noremap <leader>dp :action Debugger.PopFrame<CR>
noremap <leader>pp :action ShowExecutionPoint<CR>
noremap <leader>ds :action StreamTracerAction<CR>
noremap <leader>dd :action Debug<CR>
noremap <leader>dl :action DebugClass<CR>
noremap <leader>rt :action ImportTests<CR>
nmap <leader>dc <Action>(ChooseDebugConfiguration)
nmap <leader>dv <Action>(ViewBreakpoints)
" ------------------------------------------------ Version control
nmap <leader>ca <Action>(Annotate)
nmap <leader>cb <Action>(Git.Branches)
nmap <leader>cl <Action>(Vcs.Show.Log)
nmap <leader>cm <Action>(Git.Merge)
nmap <leader>co <Action>(Github.Open.In.Browser)
nmap <leader>cp <Action>(Git.Pull)
nmap <leader>cr <Action>(Git.Rebase)
nmap <leader>cs <Action>(Vcs.Show.Local.Changes)
nmap <leader>cu <Action>(Git.Push)
nmap <leader>cv <Action>(Compare.LastVersion)
nmap <leader>cw <Action>(ActivateCommitToolWindow)
nmap <leader>cc <Action>(Vcs.QuickListPopupAction)
""""""""""""""""""""""""""""""""""""""Refactoring""""""""""""""""""""""""""""""""""""""
nnoremap <leader>rr :action Refactorings.QuickListPopupAction<CR>
vnoremap <leader>rr :action Refactorings.QuickListPopupAction<CR>
"noremap <leader>re :action RenameElement<CR>
noremap <leader>mv :action Move<CR>
noremap <leader>ms :action MakeStatic<CR>
noremap <leader>ci :action ConvertToInstanceMethod<CR>
noremap <leader>il :action Inline<CR>
noremap <leader>em :action ExtractMethod<CR>
noremap <leader>ei :action ExtractInterface<CR>
noremap <leader>ef :action EncapsulateFields<CR>
noremap <leader>rmo :action ReplaceMethodWithMethodObject<CR>
noremap <leader>iv :action IntroduceVariable<CR>
noremap <leader>ic :action IntroduceConstant<CR>
noremap <leader>ip :action IntroduceParameter<CR>
noremap <leader>if :action IntroduceField<CR>
noremap <leader>po :action IntroduceParameterObject<CR>
noremap <leader>pd :action MemberPushDown<CR>
noremap <leader>pu :action MembersPullUp<CR>
noremap <leader>RF :action RenameFile<CR>
noremap <leader>cs  :action ChangeSignature<CR>
noremap <leader>ai :action AnonymousToInner<CR>
""""""""""""""""""""""""""""""""""""""Utilities""""""""""""""""""""""""""""""""
vnoremap n :action SurroundWith<CR>
noremap <leader>cap   :action CopyAbsolutePath<CR>
" noremap <leader>cr   :action CopyContentRootPath<CR>
noremap <leader>oi :action OptimizeImports<CR>
nnoremap <CR><CR> :action ShowIntentionActions<CR>
vnoremap <CR><CR> :action ShowIntentionActions<CR>
noremap <leader>ps :action ShowProjectStructureSettings<CR>
noremap <leader>ri :action RevealIn<CR>
nnoremap n :action Generate<CR>

""""""""""""""""""""""""""""""""""""""Information""""""""""""""""""""""""""""""""""""""
noremap <leader>ti :action ExpressionTypeInfo<CR>
noremap <leader>fs mm`m:action FileStructurePopup<CR>
noremap <leader>sd  :action ShowUmlDiagram<CR>
noremap <leader>ch :action CallHierarchy<CR>
nnoremap <leader>fu :action FindUsages<CR>
nnoremap <leader>su :action ShowUsages<CR>
noremap <leader>mh :action MethodHierarchy<CR>
noremap <leader>ps :action ShowProjectStructureSettings<CR>
" IDE handlers
sethandler <c-a> a:ide
sethandler <c-x> a:ide
sethandler <c-f> a:ide
sethandler <c-p> a:ide
sethandler <c-n> a:ide
sethandler <c-e> a:ide
sethandler <c-o> a:ide
sethandler <c-i> a:ide
sethandler <c-l> a:ide n:vim
sethandler <c-k> a:ide
sethandler <c-h> a:ide n:vim
sethandler <c-r> a:ide
sethandler <c-j> a:ide
sethandler <c-b> a:ide
sethandler <c-g> a:ide
sethandler <a-p> a:ide
sethandler <c-v> a:ide
sethandler <c-c> a:ide
sethandler <c-t> a:ide
sethandler <c-d> a:ide
"" Vim handlers
sethandler <c-s> a:vim
sethandler <c-w> a:vim
sethandler <s-cr> n:vim

